{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "rm *": "deny",
            "npm *": "deny",
            "pip3 *": "deny",
            "ls *": "allow",
            "cat *": "allow",
            "find *": "allow",
            "grep *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "wc *": "allow",
            "git status *": "allow",
            "git show *": "allow",
            "git diff *": "allow",
            "git log *": "allow"
        }
    },
    "agent": {
        // "general": {
        //     "mode": "subagent",
        //     "model": "openrouter/minimax/minimax-m2.5"
        // },
        // "explore": {
        //     "mode": "subagent",
        //     "model": "openrouter/minimax/minimax-m2.5"
        // }
    },
    "mcp": {
        "github": {
            "type": "remote",
            "url": "https://api.githubcopilot.com/mcp/",
            "oauth": false,
            "headers": {
                "Authorization": "Bearer {env:GITHUB_MCP_PAT}"
            }
        },
        "markitdown": {
            "type": "local",
            "command": [
                "uvx",
                "markitdown-mcp"
            ]
        }
    },
}
